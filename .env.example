# ── PostgreSQL ────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://opendesign:opendesign@localhost:5432/opendesign_qa"

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ── MinIO / S3-compatible storage ─────────────────────────────────────────────
STORAGE_ENDPOINT="http://localhost:9000"
STORAGE_ACCESS_KEY="minioadmin"
STORAGE_SECRET_KEY="minioadmin"
STORAGE_BUCKET="opendesign-qa"
STORAGE_REGION="us-east-1"
# Set to "s3" for real AWS S3, "minio" for local MinIO
STORAGE_PROVIDER="minio"

# ── API service ───────────────────────────────────────────────────────────────
API_PORT=3001
API_HOST="0.0.0.0"

# ── Web app ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL="http://localhost:3001"

# ── Figma (optional) ───────────────────────────────────────────────────────────
# Required if you want real exported frame images for figma.com/design links.
# Without a token, the API falls back to the local placeholder artifact.
# FIGMA_ACCESS_TOKEN="your-figma-personal-access-token"

# ── Worker ───────────────────────────────────────────────────────────────────
WORKER_CONCURRENCY=2
