{
  "name": "opendesign-qa",
  "version": "0.0.0",
  "private": true,
  "description": "Open-source visual design QA platform — audit live websites and compare against Figma designs",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test --filter=!@opendesign-qa/e2e",
    "test:all": "turbo run test",
    "test:coverage": "turbo run test:coverage",
    "db:migrate": "pnpm --filter @opendesign-qa/db run migrate",
    "db:generate": "pnpm --filter @opendesign-qa/db run generate",
    "db:seed": "pnpm --filter @opendesign-qa/db run seed",
    "dev:api": "pnpm --filter @opendesign-qa/api run dev",
    "dev:worker": "pnpm --filter @opendesign-qa/worker run dev",
    "dev:web": "pnpm --filter @opendesign-qa/web run dev",
    "test:e2e": "pnpm --filter @opendesign-qa/e2e run test",
    "test:e2e:headed": "pnpm --filter @opendesign-qa/e2e run test:headed",
    "test:e2e:ui": "pnpm --filter @opendesign-qa/e2e run test:ui",
    "test:e2e:cross-browser": "pnpm --filter @opendesign-qa/e2e run test:cross-browser",
    "test:e2e:cross-browser:headed": "pnpm --filter @opendesign-qa/e2e run test:cross-browser:headed",
    "test:e2e:mobile": "pnpm --filter @opendesign-qa/e2e run test:mobile",
    "test:e2e:mobile:headed": "pnpm --filter @opendesign-qa/e2e run test:mobile:headed",
    "test:e2e:all-browsers": "pnpm --filter @opendesign-qa/e2e run test:all-browsers",
    "test:e2e:story": "pnpm --filter @opendesign-qa/e2e run test:story",
    "test:e2e:story:headed": "pnpm --filter @opendesign-qa/e2e run test:story:headed",
    "test:e2e:story:smoke": "pnpm --filter @opendesign-qa/e2e run test:story:smoke",
    "test:e2e:story:smoke:headed": "pnpm --filter @opendesign-qa/e2e run test:story:smoke:headed"
  },
  "devDependencies": {
    "node-fetch": "^3.3.2",
    "turbo": "^2.3.3"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.0"
}
