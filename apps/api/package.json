{
  "name": "@opendesign-qa/api",
  "version": "0.0.0",
  "private": true,
  "description": "API service for OpenDesign QA",
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "dev": "tsx watch --env-file=../../.env src/index.ts",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@opendesign-qa/capture": "workspace:*",
    "@opendesign-qa/contracts": "workspace:*",
    "@opendesign-qa/db": "workspace:*",
    "@opendesign-qa/reporting": "workspace:*",
    "bullmq": "^5.76.2",
    "fastify": "^5.8.5",
    "fastify-zod-openapi": "^5.6.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@opendesign-qa/config": "workspace:*",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^2.1.8",
    "pino-pretty": "^13.1.3",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
