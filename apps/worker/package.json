{
  "name": "@opendesign-qa/worker",
  "version": "0.0.0",
  "private": true,
  "description": "Worker service for OpenDesign QA",
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "dev": "node --watch --experimental-strip-types src/index.ts",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@opendesign-qa/capture": "workspace:*",
    "@opendesign-qa/compare": "workspace:*",
    "@opendesign-qa/contracts": "workspace:*",
    "@opendesign-qa/db": "workspace:*",
    "@opendesign-qa/figma": "workspace:*",
    "@opendesign-qa/rules-core": "workspace:*",
    "@opendesign-qa/rules-web": "workspace:*",
    "@opendesign-qa/storage": "workspace:*",
    "bullmq": "^5.76.2",
    "pino": "^10.3.1"
  },
  "devDependencies": {
    "@opendesign-qa/config": "workspace:*",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^2.1.8",
    "pino-pretty": "^13.1.3",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
