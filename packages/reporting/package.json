{
  "name": "@opendesign-qa/reporting",
  "version": "0.0.0",
  "private": true,
  "description": "Report generation for OpenDesign QA — JSON and Markdown export",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@opendesign-qa/contracts": "workspace:*"
  },
  "devDependencies": {
    "@opendesign-qa/config": "workspace:*",
    "@types/node": "^22.10.2",
    "@vitest/coverage-v8": "^2.1.8",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
